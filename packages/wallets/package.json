{
  "name": "@bamzzstudio/cforge-wallets",
  "version": "0.1.0",
  "description": "MiniPay detection and Celo fee-currency wallet helpers for C-forge.",
  "type": "module",
  "homepage": "https://github.com/AdekunleBamz/C-forge-sdk/tree/main/packages/wallets#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdekunleBamz/C-forge-sdk.git",
    "directory": "packages/wallets"
  },
  "bugs": {
    "url": "https://github.com/AdekunleBamz/C-forge-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "license": "MIT",
  "keywords": [
    "cforge",
    "celo",
    "minipay",
    "wallet",
    "fee-currency"
  ],
  "dependencies": {
    "@bamzzstudio/cforge-addresses": "^0.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  }
}
