{
  "name": "@bamzzstudio/cforge-abi",
  "version": "0.1.0",
  "description": "C-forge CFRG token and ERC-20 approval ABIs.",
  "type": "module",
  "homepage": "https://github.com/AdekunleBamz/C-forge-sdk/tree/main/packages/abi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdekunleBamz/C-forge-sdk.git",
    "directory": "packages/abi"
  },
  "bugs": {
    "url": "https://github.com/AdekunleBamz/C-forge-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "license": "MIT",
  "keywords": [
    "cforge",
    "celo",
    "erc-20",
    "abi"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  }
}
